<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
   http://www.liquibase.org/xml/ns/dbchangelog
   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">


    <changeSet id="enable-pgcrypto" author="you">
        <sql>CREATE
        EXTENSION IF NOT EXISTS pgcrypto;</sql>
    </changeSet>

    <changeSet id="load-books" author="you">
        <loadUpdateData
                file="liquibase/dataset/books.csv"
                tableName="novel"
                separator=";"
                primaryKey="title"
                encoding="UTF-8">

            <column name="title" type="STRING"/>
            <column name="author" type="STRING"/>
            <column name="cover_img_url" type="STRING"/>

        </loadUpdateData>

    </changeSet>

    <changeSet id="fix-public-id" author="you">
        <sql>
            UPDATE novel
            SET public_id = gen_random_uuid()
            WHERE public_id IS NULL;
        </sql>
    </changeSet>

</databaseChangeLog>

